/*  Residuals Test for Normality (Change DATA=STATEALL... as appropriate)  */
PROC UNIVARIATE DATA=STATEALL.PREDICTIONS2025BETA NORMAL;
    
    VAR Res;
    HISTOGRAM Res / NORMAL(MU=EST SIGMA=EST) KERNEL;
    
RUN;

/* ##########################################################################################
   ### Model 2 Specification. Response: Events/Trials (Discrete). Distribution: Binomial. ###
   ########################################################################################## */

/* Scale Events and Trials (Change STATEALL... as appropriate) */
DATA STATEALL.DATA2025;
	SET STATEALL.DATA2025;
	
	/* Calculate the fraction of the total population for a given year that is represented by each state */
	StateShareOfTotalPopForYear = StatePopulation/TotalPopulationForYear;
	
	/* For each year, scale the NationalTrials so that the scaled NationalTrials divied by the scaled NationalEvents in that year equals the unweighted NYTS sample size that year.
	   Note that while the exact sample size will not be known exactly if the national survey is not available, an estimate based on previous years is perfectly sufficient for scaling, e.g. 20,000 */
	if Year = 2011 then NationalTrialsScaled = 18866*StateShareOfTotalPopForYear;
	if Year = 2012 then NationalTrialsScaled = 24658*StateShareOfTotalPopForYear;
	if Year = 2013 then NationalTrialsScaled = 18406*StateShareOfTotalPopForYear;
	if Year = 2014 then NationalTrialsScaled = 22007*StateShareOfTotalPopForYear;
	if Year = 2015 then NationalTrialsScaled = 17711*StateShareOfTotalPopForYear;
	if Year = 2016 then NationalTrialsScaled = 20675*StateShareOfTotalPopForYear;
	if Year = 2017 then NationalTrialsScaled = 17872*StateShareOfTotalPopForYear;
	if Year = 2018 then NationalTrialsScaled = 20189*StateShareOfTotalPopForYear;
	if Year = 2019 then NationalTrialsScaled = 19018*StateShareOfTotalPopForYear;
	if Year = 2020 then NationalTrialsScaled = 14531*StateShareOfTotalPopForYear;
	if Year = 2021 then NationalTrialsScaled = 20413*StateShareOfTotalPopForYear;
	if Year = 2022 then NationalTrialsScaled = 28291*StateShareOfTotalPopForYear;
	if Year = 2023 then NationalTrialsScaled = 22069*StateShareOfTotalPopForYear;
	if Year = 2024 then NationalTrialsScaled = 29861*StateShareOfTotalPopForYear;
	if Year = 2025 then NationalTrialsScaled = 23630*StateShareOfTotalPopForYear;
	
	/* Scale the NationalEvents so that the sum across states in a given year divided by the unweighted NYTS sample size that year equals the weighted NYTS prevalence that year */
	NationalEventsScaled = NationalPrevalence*NationalTrialsScaled;
	
RUN;

/* Generalised Linear Mixed Effects Model (Change DATA=STATEALL... as appropriate) */
PROC GLIMMIX DATA=STATEALL.DATA2025;
	
