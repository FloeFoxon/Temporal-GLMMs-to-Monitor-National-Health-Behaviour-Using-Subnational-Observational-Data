/* Import Dataset from Excel File */
%if %sysfunc(exist(STATEALL.'DATA'n)) %then %do;
PROC SQL;
    DROP TABLE STATEALL.'DATA'n;
RUN;
%end;
/* (Your file path goes here) */
FILENAME REFFILE 'C:/Users/FloeFoxon/.../Data.xlsx';
PROC IMPORT DATAFILE=REFFILE

	DBMS=XLSX
	OUT=STATEALL.'DATA'n;
	GETNAMES=YES;
	
RUN;
PROC CONTENTS DATA=STATEALL.'DATA'n; 
RUN;
%web_open_table(STATEALL.'DATA'n);

/* Sort Dataset by State */
PROC SORT DATA=STATEALL.DATA;

   BY STATE;
   
RUN;

/* Remove Data from Years >=T+1 (Blind Predictions) */
DATA STATEALL.DATA;
	SET STATEALL.DATA;
	
	*NationalEvents = round(NationalEvents/1000, 1);
	*NationalTrials = round(NationalTrials/1000, 1);
	
	/* (Uncomment one of the blocks below) */
	
	/* For T+1 = 2022 */
	/*
	if Year = 2022 then NationalEvents = '.';
    if Year = 2022 then NationalTrials = '.';
    if Year = 2022 then NationalPrevalence = '.';
	if Year > 2022 then delete;
	*/
	
	/* For T+1 = 2023 */
	/*
	if Year = 2023 then NationalEvents = '.';
    if Year = 2023 then NationalTrials = '.';
    if Year = 2023 then NationalPrevalence = '.';
	if Year > 2023 then delete;
	*/
	
	/* For T+1 = 2024 */
	/*
	if Year = 2024 then NationalEvents = '.';
    if Year = 2024 then NationalTrials = '.';
    if Year = 2024 then NationalPrevalence = '.';
	if Year > 2024 then delete;
	*/
	
	/* For T+1 = 2025 */
	
	if Year = 2025 then NationalEvents = '.';
    if Year = 2025 then NationalTrials = '.';
    if Year = 2025 then NationalPrevalence = '.';
   	if Year > 2025 then delete;
    
	
RUN;

/* Subset Dataset to States with Data for Year T+1 and At Least Two Years != T+1 Only.
   After Subsetting, Sum State Prevalence in Each Year (For Alternative Model Specification).
   (Change CREATE TABLE STATEALL... as appropriate) */
PROC SQL;
	
	CREATE TABLE STATEALL.DATA2025 AS
    SELECT *,
    	SUM(StatePopulation) AS TotalPopulationForYear
    FROM (
    	SELECT * 
    	FROM STATEALL.DATA
    	GROUP BY STATE
    	/* (Uncomment one of the lines below) */
    	/* HAVING SUM(YEAR eq 2022) > 0 AND SUM(YEAR ne 2022) > 1 */
    	/* HAVING SUM(YEAR eq 2023) > 0 AND SUM(YEAR ne 2023) > 1 */
    	/* HAVING SUM(YEAR eq 2024) > 0 AND SUM(YEAR ne 2024) > 1 */
    	HAVING SUM(YEAR eq 2025) > 0 AND SUM(YEAR ne 2025) > 1
   )
   GROUP BY Year;
QUIT;

/* Delete Original, Non-Subset Dataset (No Longer Needed) */
PROC DELETE DATA=STATEALL.DATA;
RUN;

/* Sort Data by Year (Change DATA=STATEALL... as appropriate) */
PROC SORT DATA=STATEALL.DATA2025;

	BY Year;
	
RUN;

